{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "types": ["node", "mocha", "chai"]
  },
  "include": ["./hardhat.config.ts", "./scripts/**/*.ts", "./test/**/*.ts"],
  "exclude": ["node_modules", "frontend"]
}
