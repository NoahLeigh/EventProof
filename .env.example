# ─── Contract Deployment ───────────────────────────────────────────────────────
# Your wallet private key (without 0x prefix) — used ONLY for deploying the contract
DEPLOYER_PRIVATE_KEY=your_private_key_here

# ARC Testnet RPC (default works, override if using a provider)
ARC_RPC_URL=https://rpc.testnet.arc.network

# ArcScan API key (optional, for contract verification)
ARCSCAN_API_KEY=
